{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Locus",
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg"
  },
  "description": "Documentation for the Locus Unity Dev Agent workspace.",
